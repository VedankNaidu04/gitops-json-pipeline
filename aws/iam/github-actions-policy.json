{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListPipelineBucket",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": "arn:aws:s3:::gitops-json-pipeline-vedank"
        },
        {
            "Sid": "ManagePipelineArtifacts",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject"
            ],
            "Resource": "arn:aws:s3:::gitops-json-pipeline-vedank/*"
        }
    ]
}